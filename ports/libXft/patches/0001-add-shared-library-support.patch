+++ libXft-2.3.9-banan_os/configure	2025-11-17 01:42:42.971908492 +0200
@@ -5873,6 +5873,10 @@
   lt_cv_deplibs_check_method=pass_all
   ;;
 
+banan_os*)
+  lt_cv_deplibs_check_method=pass_all
+  ;;
